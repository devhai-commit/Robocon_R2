import os
from ament_index_python.packages import get_package_share_directory
from launch import LaunchDescription
from launch_ros.actions import Node
from launch.actions import TimerAction

def generate_launch_description():
    pkg_dir = get_package_share_directory('robot_hw_interface')
    urdf_file = os.path.join(pkg_dir, 'urdf', 'test_robot.urdf')
    config_file = os.path.join(pkg_dir, 'config', 'controllers.yaml')

    # Đọc nội dung file URDF
    with open(urdf_file, 'r') as infp:
        robot_desc = infp.read()

    # Khởi chạy node Controller Manager lõi
    controller_manager = Node(
        package='controller_manager',
        executable='ros2_control_node',
        parameters=[{'robot_description': robot_desc}, config_file],
        output='screen'
    )

    # Khởi chạy Joint State Broadcaster (Đọc trạng thái)
    jsb_spawner = Node(
        package='controller_manager', 
        executable='spawner', 
        arguments=['joint_state_broadcaster'],
    )
    
    # Khởi chạy Velocity Controller (Điều khiển 6 bánh xe)
    vel_spawner = Node(
        package='controller_manager', 
        executable='spawner', 
        arguments=['velocity_controller'],
    )
    
    # Khởi chạy Position Controller (Điều khiển 2 động cơ lái)
    pos_spawner = Node(
        package='controller_manager', 
        executable='spawner', 
        arguments=['position_controller'],
    )

    # Dùng TimerAction để delay việc khởi chạy các controller,
    # đảm bảo controller_manager đã load xong cấu hình phần cứng.
    return LaunchDescription([
        controller_manager,
        TimerAction(period=2.0, actions=[jsb_spawner]),
        TimerAction(period=4.0, actions=[vel_spawner]),
        TimerAction(period=6.0, actions=[pos_spawner]),
    ])
