<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="wheel_module" params="index x y">
    
    <link name="steer_${index}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.03" length="0.05"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.03" length="0.05"/></geometry>
      </collision>
      <xacro:cylinder_inertia_z m="${steer_mass}" r="0.03" l="0.05"/>
    </link>

    <joint name="wheel_steer_${index}" type="revolute">
      <parent link="base_link"/>
      <child link="steer_${index}"/>
      <origin xyz="${x} ${y} 0.152" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.5708" upper="1.5708" effort="50" velocity="3.14"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>

    <link name="wheel_${index}">
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia_y m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>

    <joint name="wheel_joint_${index}" type="continuous">
      <parent link="steer_${index}"/>
      <child link="wheel_${index}"/>
      <origin xyz="0 0 -0.0855" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>

  </xacro:macro>
</robot>