<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="arm_1"> 
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.4 0.02"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="arm_joint_1" type="prismatic">
    <parent link="base_link"/>
    <child link="arm_1"/>
    <origin xyz="0.365 0.0 0.077" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.75" effort="5" velocity="1.0"/>
  </joint>

  <link name="arm_2"> 
    <visual>
      <origin xyz="0.0 0 0.155" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.310"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  
  <joint name="arm_joint_2" type="revolute">
    <parent link="arm_1"/>
    <child link="arm_2"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="3.14"/>
  </joint>

  <link name="arm_3">
    <visual>
      <origin xyz="0 0 0.0325" rpy="0 0 0"/>
      <geometry><cylinder radius="0.02" length="0.065"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="arm_joint_3" type="revolute">
    <parent link="arm_2"/>
    <child link="arm_3"/>
    <origin xyz="0 0 0.31" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="0.3"/>
  </joint>
  
  <link name="gripper_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.02 0.08 0.02"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="gripper_joint" type="revolute">
    <parent link="arm_3"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-1.57" upper="1.57" effort="50" velocity="3.14"/>
  </joint>

</robot>